{
  "$schema": "https://static.modelcontextprotocol.io/schemas/v1/server-card.schema.json",
  "name": "com.refined-x/public-ask",
  "version": "1.0.0",
  "description": "检索 Refined-X 公开文章、FAQ 与个人资料（NLWeb ask）。",
  "title": "Refined-X Public Ask",
  "websiteUrl": "https://refined-x.com/",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://ask.refined-x.com/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "可选 Bearer API Key。匿名默认 list；summarize 等模式需要凭据。",
          "isRequired": false,
          "isSecret": true,
          "value": "Bearer {token}",
          "variables": {
            "token": {
              "description": "机器 API Key（可选）",
              "isRequired": false,
              "isSecret": true
            }
          }
        }
      ],
      "supportedProtocolVersions": [
        "2024-11-05"
      ]
    }
  ],
  "_meta": {
    "com.refined-x/discovery": {
      "healthUrl": "https://ask.refined-x.com/health",
      "aboutUrl": "https://refined-x.com/.well-known/about.json",
      "openapiUrl": "https://refined-x.com/openapi.json",
      "siteDescription": "欢迎来到师兄的林间小屋——一个专注前端工程与 AI 实践的个人博客。记录十余年前端架构与工程化经验，以及 AI 辅助研发、Agent 协作和职业复盘。",
      "access": "public-read-only"
    }
  }
}
